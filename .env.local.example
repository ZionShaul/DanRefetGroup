# ===== Supabase =====
# מתוך Project Settings > API ב-Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service Role – סודי! צד שרת בלבד (יצירת משתמשים, פרסום). אין לחשוף לדפדפן.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# שם ה-bucket לאחסון קבצי האקסל שנטענו (ברירת מחדל: uploads)
SUPABASE_UPLOADS_BUCKET=uploads

# ===== כתובת האתר (לקישורים/אימות) =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
